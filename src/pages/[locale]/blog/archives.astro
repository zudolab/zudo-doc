---
import DocLayout from "@/layouts/doc-layout.astro";
import { loadBlogPosts, getBlogConfig, getBlogLocales } from "@/utils/blog";
import { t, type Locale } from "@/config/i18n";
import { withBase } from "@/utils/base";
import { toRouteSlug } from "@/utils/slug";

export async function getStaticPaths() {
  // Skip locale routes when blog is disabled or no blog locales configured.
  // Iterate `getBlogLocales()` (keys of settings.blog.locales) — never
  // `settings.locales`, which is the docs locale list.
  if (!getBlogConfig()) return [];
  const blogLocales = getBlogLocales();
  if (blogLocales.length === 0) return [];

  return (blogLocales as Locale[]).map((locale) => ({
    params: { locale },
  }));
}

const lang = Astro.params.locale as Locale;

const { allPosts } = await loadBlogPosts(lang);
// allPosts is already sorted newest-first, draft-filtered, and locale-merged
// with EN fallback by loadBlogPosts. Hide unlisted posts from the archives.
const visiblePosts = allPosts.filter((p) => !p.data.unlisted);

// Format dates against UTC so a YYYY-MM-DD frontmatter date does not shift
// by a day depending on the build server's local timezone.
const dateFormatter = new Intl.DateTimeFormat(lang, {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});

const archivesTitle = t("blog.archives", lang);
const noPostsLabel = t("blog.noPosts", lang);

function postUrl(slug: string): string {
  return withBase(`/${lang}/blog/${slug}`);
}
---

<DocLayout
  title={archivesTitle}
  lang={lang}
  currentSlug="blog/archives"
  navSection="blog"
  hideToc
>
  <Fragment>
    <h1 class="text-heading font-bold mb-vsp-lg">{archivesTitle}</h1>

    {
      visiblePosts.length === 0 ? (
        <p class="text-muted">{noPostsLabel}</p>
      ) : (
        <ul class="list-none p-0 m-0 flex flex-col gap-vsp-sm">
          {visiblePosts.map((post) => {
            const slug = post.data.slug ?? toRouteSlug(post.id);
            const href = postUrl(slug);
            const iso = post.data.date.toISOString();
            const formatted = dateFormatter.format(post.data.date);
            return (
              <li class="flex flex-wrap items-baseline gap-x-hsp-md gap-y-vsp-2xs">
                <time
                  datetime={iso}
                  class="text-caption text-muted shrink-0 tabular-nums"
                >
                  {formatted}
                </time>
                <a
                  href={href}
                  class="text-fg underline hover:text-accent break-words"
                >
                  {post.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      )
    }
  </Fragment>
</DocLayout>
