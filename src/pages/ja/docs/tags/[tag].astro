---
import { getDocsCollection } from "@/utils/get-docs-collection";
import DocLayout from "@/layouts/doc-layout.astro";
import Breadcrumb from "@/components/breadcrumb.astro";
import { toRouteSlug } from "@/utils/slug";
import { collectTags } from "@/utils/tags";
import { t } from "@/config/i18n";
import { docsUrl, withBase } from "@/utils/base";
import type { DocsEntry } from "@/types/docs-entry";

export async function getStaticPaths() {
  const localeDocs = await getDocsCollection("docs-ja");
  const baseDocs = await getDocsCollection("docs");
  const filterDocs = (docs: DocsEntry[]) => import.meta.env.PROD
    ? docs.filter((doc) => !doc.data.draft && !doc.data.unlisted)
    : docs.filter((doc) => !doc.data.unlisted);
  const filteredLocale = filterDocs(localeDocs);
  const filteredBase = filterDocs(baseDocs);
  const localeSlugSet = new Set(filteredLocale.map((d) => d.data.slug ?? toRouteSlug(d.id)));
  const docs = [
    ...filteredLocale,
    ...filteredBase.filter((d) => !localeSlugSet.has(d.data.slug ?? toRouteSlug(d.id))),
  ];
  const tagMap = collectTags(docs, (id, data) => data.slug ?? toRouteSlug(id));

  return [...tagMap.entries()].map(([tag, info]) => ({
    params: { tag },
    props: { tagInfo: info },
  }));
}

const { tag } = Astro.params;
const { tagInfo } = Astro.props;
const countText = tagInfo.count === 1
  ? t("doc.pageCountSingle", "ja").replace("{count}", String(tagInfo.count))
  : t("doc.pageCount", "ja").replace("{count}", String(tagInfo.count));
---

<DocLayout title={`${t("doc.taggedWith", "ja")}: ${tag}`} lang="ja" currentSlug={`tags/${tag}`}>
  <Breadcrumb slot="breadcrumb" items={[
    { label: "Docs", href: withBase("/ja/docs") },
    { label: t("doc.allTags", "ja"), href: withBase("/ja/docs/tags") },
    { label: tag },
  ]} />
  <h1 class="text-heading font-bold mb-vsp-xs">{t("doc.taggedWith", "ja")}: {tag}</h1>
  <p class="text-muted mb-vsp-lg">{countText}</p>

  <nav class="grid grid-cols-1 gap-y-vsp-md">
    {tagInfo.docs.map((doc) => (
      <a
        href={docsUrl(doc.slug, "ja")}
        class="group block border border-muted bg-surface px-hsp-lg py-vsp-md hover:border-accent"
      >
        <span class="font-medium text-accent underline group-hover:underline">{doc.title}</span>
        {doc.description && (
          <span class="mt-vsp-2xs block text-small text-muted group-hover:underline decoration-muted">{doc.description}</span>
        )}
      </a>
    ))}
  </nav>
</DocLayout>
