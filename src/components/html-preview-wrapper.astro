---
import HtmlPreview from "./html-preview/html-preview";

interface Props {
  html: string;
  css?: string;
  title?: string;
  height?: number;
  defaultOpen?: boolean;
}

const { html, css, title, height, defaultOpen } = Astro.props;
---
<HtmlPreview client:visible html={html} css={css} title={title} height={height} defaultOpen={defaultOpen} />
