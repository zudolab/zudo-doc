---
import { getCollection } from "astro:content";
import SidebarTree from "@/components/sidebar-tree";
import { loadCategoryMeta } from "@/utils/docs";
import { buildSidebarForSection } from "@/utils/sidebar";
import { defaultLocale, getCollectionName, getContentDir, type Locale } from "@/config/i18n";
import type { DocsEntry } from "@/types/docs-entry";

interface Props {
  currentSlug?: string;
  lang?: Locale;
  navSection?: string;
}

const { currentSlug, lang = defaultLocale, navSection } = Astro.props;

const docs = await getCollection(getCollectionName(lang)) as unknown as DocsEntry[];
const contentDir = getContentDir(lang);
const categoryMeta = loadCategoryMeta(contentDir);
const nodes = buildSidebarForSection(docs, lang, navSection, categoryMeta);
---

<SidebarTree nodes={nodes} currentSlug={currentSlug} client:load />
