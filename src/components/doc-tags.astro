---
import TagNav from "./tag-nav.astro";
import { settings } from "@/config/settings";
import type { Locale } from "@/config/i18n";
import type { TagPlacement } from "@/config/settings-types";
import { resolvePageTags } from "@/utils/tags";

interface Props {
  tags: string[];
  locale?: Locale;
  placement: TagPlacement;
}

const { tags, locale = "en", placement } = Astro.props;

const resolvedTags = resolvePageTags(tags);

const spacingClass =
  placement === "after-title" ? "mt-0 mb-vsp-md" : "mt-vsp-xl mb-0";
---

{
  settings.docTags && resolvedTags.length > 0 && (
    <div class={spacingClass}>
      <TagNav variant="page" tags={resolvedTags} locale={locale} />
    </div>
  )
}
