---
import { settings } from "@/config/settings";
import { docsUrl, versionedDocsUrl, withBase } from "@/utils/base";
import { t, defaultLocale, type Locale } from "@/config/i18n";
import type { VersionAvailability } from "@/utils/version-availability";

interface Props {
  currentVersion?: string;
  currentSlug?: string;
  lang?: Locale;
  availability?: VersionAvailability;
  idSuffix?: string;
}

const {
  currentVersion,
  currentSlug,
  lang = defaultLocale,
  availability,
  idSuffix = "",
} = Astro.props;
const menuId = `version-menu${idSuffix ? `-${idSuffix}` : ""}`;
const versions = settings.versions;
if (!versions) return;

const latestLabel = t("version.latest", lang);
const switcherLabel = t("version.switcher.label", lang);
const unavailableLabel = t("version.switcher.unavailable", lang);
const allVersionsLabel = t("version.switcher.allVersions", lang);
const isNonDefaultLocale = lang !== defaultLocale;
const versionsPageUrl = withBase(
  isNonDefaultLocale ? `/${lang}/docs/versions` : "/docs/versions",
);
const latestUrl = currentSlug ? docsUrl(currentSlug, lang) : versionsPageUrl;
const isLatest = !currentVersion;
---

<div class="version-switcher relative" data-version-switcher>
  <button
    type="button"
    class="flex items-center gap-hsp-2xs border border-muted rounded px-hsp-sm py-vsp-3xs text-small text-muted hover:border-accent hover:text-accent transition-colors cursor-pointer whitespace-nowrap"
    aria-expanded="false"
    aria-controls={menuId}
    data-version-toggle
  >
    <span class="text-caption">{switcherLabel}:</span>
    <span class="font-medium">
      {
        isLatest
          ? latestLabel
          : (versions.find((v) => v.slug === currentVersion)?.label ??
            currentVersion)
      }
    </span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-[0.875rem] w-[0.875rem]"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"
      ></path>
    </svg>
  </button>

  <ul
    id={menuId}
    class="absolute right-0 top-full z-10 mt-vsp-3xs hidden min-w-[8rem] border border-muted rounded bg-surface shadow-lg whitespace-nowrap"
    data-version-menu
  >
    <li>
      <a
        href={latestUrl}
        aria-current={isLatest ? "page" : undefined}
        class:list={[
          "block px-hsp-md py-vsp-3xs text-small hover:bg-accent/10",
          isLatest ? "font-bold text-accent" : "text-fg",
        ]}
      >
        {latestLabel}
      </a>
    </li>
    {
      versions.map((v) => {
        const vUrl = currentSlug
          ? versionedDocsUrl(currentSlug, v.slug, lang)
          : versionsPageUrl;
        const isActive = currentVersion === v.slug;
        const isAvailable =
          !currentSlug ||
          !availability ||
          (availability[v.slug]?.has(currentSlug) ?? false);
        return (
          <li>
            {isAvailable ? (
              <a
                href={vUrl}
                aria-current={isActive ? "page" : undefined}
                class:list={[
                  "block px-hsp-md py-vsp-3xs text-small hover:bg-accent/10",
                  isActive ? "font-bold text-accent" : "text-fg",
                ]}
              >
                {v.label}
              </a>
            ) : (
              <a
                href={vUrl}
                aria-disabled="true"
                tabindex={-1}
                class="block px-hsp-md py-vsp-3xs text-small text-muted/50 cursor-not-allowed pointer-events-none"
                title={unavailableLabel}
              >
                {v.label}
              </a>
            )}
          </li>
        );
      })
    }
    <li class="border-t border-muted">
      <a
        href={versionsPageUrl}
        class="block px-hsp-md py-vsp-3xs text-small text-muted hover:bg-accent/10 hover:text-fg"
      >
        {allVersionsLabel}
      </a>
    </li>
  </ul>
</div>

<script>
  let cleanupController: AbortController | null = null;

  function initVersionSwitcher() {
    cleanupController?.abort();
    cleanupController = new AbortController();
    const { signal } = cleanupController;

    document
      .querySelectorAll<HTMLElement>("[data-version-switcher]")
      .forEach((switcher) => {
        const toggle = switcher.querySelector<HTMLButtonElement>(
          "[data-version-toggle]",
        );
        const menu = switcher.querySelector<HTMLElement>("[data-version-menu]");
        if (!toggle || !menu) return;

        toggle.addEventListener(
          "click",
          () => {
            const isOpen = !menu.classList.contains("hidden");
            menu.classList.toggle("hidden", isOpen);
            toggle.setAttribute("aria-expanded", String(!isOpen));
          },
          { signal },
        );

        document.addEventListener(
          "click",
          (e) => {
            if (!switcher.contains(e.target as Node)) {
              menu.classList.add("hidden");
              toggle.setAttribute("aria-expanded", "false");
            }
          },
          { signal },
        );

        document.addEventListener(
          "keydown",
          (e) => {
            if (e.key === "Escape" && !menu.classList.contains("hidden")) {
              menu.classList.add("hidden");
              toggle.setAttribute("aria-expanded", "false");
              toggle.focus();
            }
          },
          { signal },
        );
      });
  }

  initVersionSwitcher();
  document.addEventListener("astro:after-swap", initVersionSwitcher);
</script>
