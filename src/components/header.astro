---
import SidebarToggle from "@/components/sidebar-toggle";
import ColorSchemePicker from "@/components/color-scheme-picker";
import ThemeToggle from "@/components/theme-toggle";
import LanguageSwitcher from "@/components/language-switcher.astro";
import VersionSwitcher from "@/components/version-switcher.astro";
import Search from "@/components/search.astro";
import { settings } from "@/config/settings";
import { withBase, stripBase } from "@/utils/base";
import { defaultLocale, locales, t, type Locale } from "@/config/i18n";
import type { VersionAvailability } from "@/utils/version-availability";

interface Props {
  lang?: Locale;
  currentPath?: string;
  currentVersion?: string;
  currentSlug?: string;
  versionAvailability?: VersionAvailability;
}

const { lang, currentPath = "", currentVersion, currentSlug, versionAvailability } = Astro.props;
const isNonDefaultLocale = lang != null && lang !== defaultLocale;
const pathWithoutBase = stripBase(currentPath);
const pathForMatch = isNonDefaultLocale ? pathWithoutBase.replace(new RegExp(`^/${lang}`), "") : pathWithoutBase;
---

<header
  class="sticky top-0 z-50 flex h-[3.5rem] items-center border-b border-muted bg-surface px-hsp-lg"
>
  <SidebarToggle client:media="(max-width: 1023px)">
    <slot name="sidebar" />
    <Fragment slot="bottomContent">
      {settings.colorMode ? (
        <ThemeToggle defaultMode={settings.colorMode.defaultMode} client:load />
      ) : (
        <ColorSchemePicker client:load />
      )}
      {lang && locales.length > 1 && <LanguageSwitcher lang={lang} />}
    </Fragment>
  </SidebarToggle>

  <a href={withBase(isNonDefaultLocale ? `/${lang}/` : "/")} class="text-subheading font-bold text-fg hover:underline focus:underline">
    {settings.siteName}
  </a>

  {settings.versions && currentSlug && (
    <div class="ml-hsp-sm hidden lg:block">
      <VersionSwitcher currentVersion={currentVersion} currentSlug={currentSlug} lang={lang} availability={versionAvailability} />
    </div>
  )}

  <nav aria-label="Main" class="ml-hsp-xl hidden items-center gap-x-hsp-2xs whitespace-nowrap lg:flex">
    {(() => {
      // Longest-prefix match: only highlight the most specific nav item
      const activeNavPath = settings.headerNav
        .filter((item) => pathForMatch.startsWith(item.path))
        .sort((a, b) => b.path.length - a.path.length)[0]?.path;

      return settings.headerNav.map((item) => {
        const isActive = item.path === activeNavPath;
        const href = withBase(isNonDefaultLocale ? `/${lang}${item.path}` : item.path);
        return (
          <a
            href={href}
            aria-current={isActive ? "page" : undefined}
            class:list={[
              "px-hsp-md py-vsp-2xs text-small font-medium transition-colors",
              isActive
                ? "bg-fg text-bg"
                : "text-muted hover:underline focus:underline",
            ]}
          >
            {item.labelKey ? t(item.labelKey, lang) : item.label}
          </a>
        );
      });
    })()}
  </nav>

  <div class="ml-auto flex items-center gap-x-hsp-md">
    {settings.colorTweakPanel && (
      <button
        id="color-tweak-trigger"
        type="button"
        class="flex items-center justify-center text-muted transition-colors hover:text-fg"
        aria-label="Toggle color tweak panel"
        onclick="window.dispatchEvent(new CustomEvent('toggle-color-tweak-panel'))"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="13.5" cy="6.5" r="2.5" />
          <circle cx="17.5" cy="10.5" r="2.5" />
          <circle cx="8.5" cy="7.5" r="2.5" />
          <circle cx="6.5" cy="12.5" r="2.5" />
          <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z" />
        </svg>
      </button>
    )}
    <Search />
    <div class="hidden lg:flex items-center gap-x-hsp-md">
      {settings.colorMode ? (
        <ThemeToggle defaultMode={settings.colorMode.defaultMode} client:load />
      ) : (
        <ColorSchemePicker client:load />
      )}
      {lang && locales.length > 1 && <LanguageSwitcher lang={lang} />}
    </div>
  </div>
</header>
