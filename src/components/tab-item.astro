---
interface Props {
  label: string;
  value?: string;
  default?: boolean;
}
const { label, value, default: isDefault } = Astro.props;
---
<div class="tab-panel" role="tabpanel" data-tab-value={value ?? label} data-tab-label={label} data-tab-default={isDefault ? "" : undefined} hidden>
  <slot />
</div>
