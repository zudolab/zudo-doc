---
import { getPathForLocale } from "@/utils/base";
import {
  defaultLocale,
  locales,
  getLocaleLabel,
  type Locale,
} from "@/config/i18n";
import type { LocaleLink } from "@/types/locale";

interface Props {
  lang?: Locale;
}

const { lang = defaultLocale } = Astro.props;
const currentPath = Astro.url.pathname;

// Build typed locale links — same shape used by Preact SidebarFooter
const localeLinks: LocaleLink[] = locales.map((code) => ({
  code,
  label: getLocaleLabel(code),
  href: getPathForLocale(currentPath, lang, code),
  active: code === lang,
}));
---

{
  localeLinks.length > 1 && (
    <div class="flex items-center gap-x-hsp-xs text-small">
      {localeLinks.map((link, i) => (
        <>
          {i > 0 && <span class="text-muted">/</span>}
          {link.active ? (
            <span aria-current="true" class="font-medium text-fg">
              {link.label}
            </span>
          ) : (
            <a
              href={link.href}
              lang={link.code}
              class="text-muted hover:text-fg"
            >
              {link.label}
            </a>
          )}
        </>
      ))}
    </div>
  )
}
