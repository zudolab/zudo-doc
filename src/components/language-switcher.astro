---
import { buildLocaleLinks } from "@/utils/base";
import { defaultLocale, type Locale } from "@/config/i18n";

interface Props {
  lang?: Locale;
}

const { lang = defaultLocale } = Astro.props;
const localeLinks = buildLocaleLinks(Astro.url.pathname, lang);
---

{
  localeLinks.length > 1 && (
    <div class="flex items-center gap-x-hsp-xs text-small">
      {localeLinks.map((link, i) => (
        <>
          {i > 0 && <span class="text-muted">/</span>}
          {link.active ? (
            <span aria-current="true" class="font-medium text-fg">
              {link.label}
            </span>
          ) : (
            <a
              href={link.href}
              lang={link.code}
              class="text-muted hover:text-fg"
            >
              {link.label}
            </a>
          )}
        </>
      ))}
    </div>
  )
}
