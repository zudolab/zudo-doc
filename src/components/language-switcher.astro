---
import { getPathForLocale } from "@/utils/base";
import {
  defaultLocale,
  locales,
  getLocaleLabel,
  type Locale,
} from "@/config/i18n";
// Locale link shape mirrors LocaleLink from @/types/locale
// (rendering stays in Astro template; type shared with Preact SidebarFooter)

interface Props {
  lang?: Locale;
}

const { lang = defaultLocale } = Astro.props;
const currentPath = Astro.url.pathname;
---

{
  locales.length > 1 && (
    <div class="flex items-center gap-x-hsp-xs text-small">
      {locales.map((code, i) => (
        <>
          {i > 0 && <span class="text-muted">/</span>}
          {code === lang ? (
            <span aria-current="true" class="font-medium text-fg">
              {getLocaleLabel(code)}
            </span>
          ) : (
            <a
              href={getPathForLocale(currentPath, lang, code)}
              lang={code}
              class="text-muted hover:text-fg"
            >
              {getLocaleLabel(code)}
            </a>
          )}
        </>
      ))}
    </div>
  )
}
