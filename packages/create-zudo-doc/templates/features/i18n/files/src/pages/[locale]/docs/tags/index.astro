---
import DocLayout from "@/layouts/doc-layout.astro";
import Breadcrumb from "@/components/breadcrumb.astro";
import { toRouteSlug } from "@/utils/slug";
import { collectTags } from "@/utils/tags";
import { settings } from "@/config/settings";
import { t, type Locale } from "@/config/i18n";
import { loadLocaleDocs } from "@/utils/locale-docs";
import TagNav from "@/components/tag-nav.astro";
import type { DocsEntry } from "@/types/docs-entry";

export async function getStaticPaths() {
  return Object.keys(settings.locales).map((locale) => ({
    params: { locale },
  }));
}

const lang = Astro.params.locale as Locale;

const filterDocs = (docs: DocsEntry[]) =>
  import.meta.env.PROD
    ? docs.filter((doc) => !doc.data.draft && !doc.data.unlisted)
    : docs.filter((doc) => !doc.data.unlisted);

const { allDocs } = await loadLocaleDocs(lang);
const docs = filterDocs(allDocs);
const tagMap = collectTags(docs, (id, data) => data.slug ?? toRouteSlug(id));
---

<DocLayout
  title={t("doc.allTags", lang)}
  lang={lang}
  currentSlug="tags"
  hideSidebar={true}
  hideToc={true}
>
  <Breadcrumb
    slot="breadcrumb"
    items={[{ label: "Docs" }, { label: t("doc.allTags", lang) }]}
  />
  <h1 class="text-heading font-bold mb-vsp-lg">{t("doc.allTags", lang)}</h1>
  {
    tagMap.size === 0 ? (
      <p class="text-muted">{t("doc.noTags", lang)}</p>
    ) : (
      <TagNav variant="all" locale={lang} />
    )
  }
</DocLayout>
