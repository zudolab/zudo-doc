---
import DocLayout from "@/layouts/doc-layout.astro";
import BlogPostCard from "@/components/blog-post-card.astro";
import BlogPagination from "@/components/blog-pagination.astro";
import { t, type Locale } from "@/config/i18n";
import { settings } from "@/config/settings";
import { getBlogConfig } from "@/utils/blog";
import { blogPageHref, loadBlogListingPage } from "@/utils/blog-listing";

export async function getStaticPaths() {
  // Skip locale routes when no locales are configured or blog is disabled.
  if (Object.keys(settings.locales).length === 0) return [];
  if (!getBlogConfig()) return [];

  return Object.keys(settings.locales).map((locale) => ({
    params: { locale },
  }));
}

const lang = Astro.params.locale as Locale;
// `loadBlogListingPage` only returns null when the blog feature is disabled,
// and `getStaticPaths` already excluded this route in that case.
const data = (await loadBlogListingPage(lang, 1))!;
const { posts, excerpts, currentPage, lastPage } = data;

const prevHref = currentPage > 1 ? blogPageHref(currentPage - 1, lang) : null;
const nextHref =
  currentPage < lastPage ? blogPageHref(currentPage + 1, lang) : null;

const title = t("blog.title", lang);
---

<DocLayout title={title} lang={lang} navSection="blog" hideToc={true}>
  <Fragment>
    <h1 class="text-heading font-bold mb-vsp-md">{title}</h1>

    {
      posts.length === 0 ? (
        <p class="text-muted">{t("blog.noPosts", lang)}</p>
      ) : (
        <ul class="list-none p-0 m-0">
          {posts.map((entry) => (
            <li class="m-0">
              <BlogPostCard
                entry={entry}
                lang={lang}
                excerpt={excerpts.get(entry.id)!}
              />
            </li>
          ))}
        </ul>
      )
    }

    {
      lastPage > 1 && (
        <BlogPagination
          currentPage={currentPage}
          lastPage={lastPage}
          lang={lang}
          prevHref={prevHref}
          nextHref={nextHref}
        />
      )
    }
  </Fragment>
</DocLayout>
