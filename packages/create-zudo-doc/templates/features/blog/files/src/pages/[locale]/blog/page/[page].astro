---
import DocLayout from "@/layouts/doc-layout.astro";
import BlogPostCard from "@/components/blog-post-card.astro";
import BlogPagination from "@/components/blog-pagination.astro";
import { t, type Locale } from "@/config/i18n";
import { getBlogConfig, getBlogLocales } from "@/utils/blog";
import {
  blogPageHref,
  getBlogExtraPagePaths,
  loadBlogListingPage,
} from "@/utils/blog-listing";

export async function getStaticPaths() {
  if (!getBlogConfig()) return [];
  const blogLocales = getBlogLocales();
  if (blogLocales.length === 0) return [];

  const paths: { params: { locale: string; page: string } }[] = [];
  for (const locale of blogLocales) {
    const localePaths = await getBlogExtraPagePaths(locale as Locale);
    for (const sp of localePaths) {
      paths.push({ params: { locale, page: sp.params.page } });
    }
  }
  return paths;
}

const lang = Astro.params.locale as Locale;
const pageNum = Number(Astro.params.page);
const data = (await loadBlogListingPage(lang, pageNum))!;
const { posts, excerpts, currentPage, lastPage } = data;

const prevHref = currentPage > 1 ? blogPageHref(currentPage - 1, lang) : null;
const nextHref =
  currentPage < lastPage ? blogPageHref(currentPage + 1, lang) : null;

const title = `${t("blog.title", lang)} — ${t("blog.pageN", lang).replace(
  "{n}",
  String(currentPage),
)}`;
---

<DocLayout title={title} lang={lang} navSection="blog" hideToc={true}>
  <Fragment>
    <h1 class="text-heading font-bold mb-vsp-md">{t("blog.title", lang)}</h1>

    <ul class="list-none p-0 m-0">
      {
        posts.map((entry) => (
          <li class="m-0">
            <BlogPostCard
              entry={entry}
              lang={lang}
              excerpt={excerpts.get(entry.id)!}
            />
          </li>
        ))
      }
    </ul>

    <BlogPagination
      currentPage={currentPage}
      lastPage={lastPage}
      lang={lang}
      prevHref={prevHref}
      nextHref={nextHref}
    />
  </Fragment>
</DocLayout>
