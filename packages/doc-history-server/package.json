{
  "name": "@zudo-doc/doc-history-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "doc-history-server": "./dist/index.js",
    "doc-history-generate": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts",
    "dev": "tsx src/index.ts",
    "generate": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepare": "tsup src/index.ts src/cli.ts --format esm --dts --silent"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.1.1"
  }
}
