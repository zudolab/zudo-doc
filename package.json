{
  "name": "zudo-doc",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "scripts": {
    "// ── Core ─────────────────────────────────────────": "",
    "predev": "lsof -ti :4321 | xargs kill 2>/dev/null; true",
    "dev": "astro dev",
    "dev:network": "astro dev --host 0.0.0.0",
    "dev:stable": "node scripts/dev-stable.js",
    "build": "astro build",
    "preview": "astro preview",
    "// ── Quality ──────────────────────────────────────": "",
    "check": "astro sync && tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e": "bash e2e/setup-fixtures.sh && playwright test",
    "b4push": "./scripts/run-b4push.sh",
    "// ── Formatting ───────────────────────────────────": "",
    "prepare": "lefthook install --reset-hooks-path",
    "format:mdx": "pnpm dlx @takazudo/mdx-formatter --write \"src/content/**/*.{md,mdx}\"",
    "format:astro": "prettier --write \"src/**/*.astro\"",
    "format": "pnpm run format:mdx && pnpm run format:astro",
    "format:check:mdx": "pnpm dlx @takazudo/mdx-formatter --check \"src/content/**/*.{md,mdx}\"",
    "format:check:astro": "prettier --check \"src/**/*.astro\"",
    "format:check": "pnpm run format:check:mdx && pnpm run format:check:astro",
    "// ── Assets ───────────────────────────────────────": "",
    "generate:logo": "pnpm dlx @takazudo/kumiko-gen \"$(node -p \"require('./package.json').name\")-$(date +%s)\" --size 200 --zoom 5 --stroke-width 0.2 --fg \"#000000\" --bg transparent --out public/img/logo.svg",
    "// ── Skills ──────────────────────────────────────": "",
    "setup:doc-skill": "bash scripts/setup-doc-skill.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "sharp",
      "workerd"
    ],
    "patchedDependencies": {
      "astro@6.0.4": "patches/astro@6.0.4.patch"
    }
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/react": "^5.0.0",
    "@shikijs/transformers": "^4.0.1",
    "@types/hast": "^3.0.4",
    "astro": "^6.0.4",
    "clsx": "^2.1.1",
    "diff": "^8.0.3",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.38",
    "mermaid": "^11.12.3",
    "minisearch": "^7.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-katex": "^7.0.1",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "shiki": "^4.0.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.72.0"
  }
}
