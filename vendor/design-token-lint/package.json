{
  "name": "@zudolab/design-token-lint",
  "version": "0.1.0",
  "description": "Lint Tailwind CSS class names against design system tokens. Enforce semantic spacing and color tokens instead of raw numeric utilities.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "design-token-lint": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "// ── Build ───────────────────────────────────────": "",
    "build": "tsc",
    "// ── Test ────────────────────────────────────────": "",
    "test": "vitest run",
    "test:watch": "vitest",
    "// ── Lint ────────────────────────────────────────": "",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .",
    "// ── Publish ─────────────────────────────────────": "",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "keywords": [
    "design-system",
    "lint",
    "tailwind",
    "css",
    "design-tokens"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zudolab/zudo-design-token-lint.git",
    "directory": "packages/design-token-lint"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "glob": "^11.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.3"
  }
}
