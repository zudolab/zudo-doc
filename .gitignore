e2e/fixtures/*/src/hooks
e2e/fixtures/*/src/lib
e2e/fixtures/*/src/mocks
e2e/fixtures/*/src/plugins
e2e/fixtures/*/src/scripts
e2e/fixtures/*/src/styles
e2e/fixtures/*/src/types
e2e/fixtures/*/src/utils
# Copied configs (regenerated by setup-fixtures.sh)
