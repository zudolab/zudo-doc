auto-install-peers=true
trust-policy=any

# zfb-adapter-cloudflare's emitted bundle resolves miniflare via filesystem
# traversal from the bundle path / workspace root, not via Node require
# resolution. With pnpm's strict isolation default, miniflare lives only
# under node_modules/.pnpm/, so the bundle cannot find it during the
# `paths()` evaluation step of `zfb build`. Hoist miniflare (and its
# closest neighbours that the runtime probes) to the top-level node_modules
# so the bundle resolution succeeds.
public-hoist-pattern[]=miniflare
